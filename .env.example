# Required secrets (do not commit real values)
RESULT_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_B_TOKEN
SUMMARIZER_API_KEY=REPLACE_WITH_AIHUBMIX_OR_OPENAI_COMPATIBLE_KEY
# Optional: use a separate key for Gemini video experiments if desired
VIDEO_SUMMARY_API_KEY=

# Analyzer CLI reuses the same OpenAI-compatible endpoint configured in config.json
# Install runtime deps separately when enabling real browser analysis:
#   python3 -m pip install beautifulsoup4 playwright
#   python3 -m playwright install chromium

# Optional: if your extractor commands read these variables directly
AIHUBMIX_API_KEY=REPLACE_WITH_AIHUBMIX_KEY
STT_API_KEY=REPLACE_WITH_AIHUBMIX_OR_OPENAI_STT_KEY
STT_API_BASE_URL=https://aihubmix.com/v1
STT_MODEL=whisper-1
VIDEO_COOKIES_FROM_BROWSER=chrome
